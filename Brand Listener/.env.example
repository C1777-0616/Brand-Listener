# ============================================
# Brand Listener 环境变量配置文件示例
# ============================================
# 复制此文件为 .env，然后填入真实配置

# API 服务配置
PORT=8000
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=False

# 数据和日志目录
DATA_DIR=/app/data
LOG_DIR=/app/logs

# 日志级别 (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# FOLO 导出配置
FOLO_EXPORT_PATH=/app/data/exports
FOLO_EXPORT_PATTERN=*.json
FOLO_POLLING_INTERVAL_MINUTES=15
FOLO_UPDATE_LOOKBACK_HOURS=24
FOLO_DIR=/srv/competitor/folo  # 可选：FOLO 数据库导出目录

# OfficialUpdatesAgent 配置
OFFICIAL_UPDATES_AGENT_MAX_SOURCES=50
OFFICIAL_UPDATES_AGENT_TIMEOUT_SECONDS=30

# XHS (小红书) API 配置
# API_TOKEN：从小红书 API 服务商获取
XHS_API_TOKEN=your_xhs_api_token_here

# XHS Cookie（用于 OCR 分析）
# 从浏览器开发者工具获取小红书 Cookie
XHS_COOKIES=your_xhs_cookies_here

# XHS 监听目标（JSON 数组）
# 示例：["usmile_official", "colgate_china"]
XHS_MONITOR_TARGETS=[]

# XHS 搜索关键词（JSON 数组）
# 示例：["牙膏", "电动牙刷", "美白"]
XHS_SEARCH_KEYWORDS=[]

# XHS 搜索最少粉丝数
XHS_MIN_FANS=0

# XHS 每次搜索条数
XHS_SEARCH_NUM=20

# OCR 配置
OCR_MAX_IMAGES=3
OCR_TIMEOUT_SECONDS=60
OCR_ENABLED=True

# 品牌配置（JSON 路径或 URL）
# BRAND_CONFIG_SOURCE=https://example.com/brands.json
# 或本地路径：
# BRAND_CONFIG_SOURCE=/app/data/brands.json

# 注意：
# - 不要在 .env 文件中提交敏感信息（API Token、Cookie 等）
# - 在 .git/info/exclude 或 .gitignore 中排除 .env 文件
# - 只在 .env.example 中保留变量名和说明，不要保留真实值
