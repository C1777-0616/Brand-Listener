# FOLO RPA Export Configuration
FOLO_EXPORT_PATH=./data/exports  # Directory where RPA exports files
FOLO_EXPORT_PATTERN=*.json  # File pattern to watch (e.g., *.json, *.csv)
FOLO_POLLING_INTERVAL_MINUTES=15  # How often to check for new exports
FOLO_UPDATE_LOOKBACK_HOURS=24  # Look back period for updates

# Agent Configuration
OFFICIAL_UPDATES_AGENT_MAX_SOURCES=50  # Maximum number of sources to process
OFFICIAL_UPDATES_AGENT_TIMEOUT_SECONDS=30  # Timeout per source

# API Configuration (optional)
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/brand_listener.log